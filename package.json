{
  "name": "ominiterm-workspace",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": "24.13.0"
  },
  "scripts": {
    "dev": "pnpm --filter ominiterm dev",
    "build": "pnpm --filter ominiterm build && pnpm --filter @ominiterm/website build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter ominiterm test",
    "desktop:dev": "pnpm --filter ominiterm dev",
    "desktop:build": "pnpm --filter ominiterm build",
    "desktop:package": "pnpm --filter ominiterm package",
    "website:build": "pnpm --filter @ominiterm/website build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
