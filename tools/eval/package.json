{
  "name": "@ominiterm/eval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": "24.13.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "eval": "node --experimental-strip-types --no-warnings src/cli.ts",
