{
  "name": "@ominiterm/hydra",
  "version": "0.1.0",
  "description": "Hydra sub-agent spawner for OminiTerm",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": "24.13.0"
  },
  "bin": {
    "hydra": "./dist/hydra.js"
  },
  "scripts": {
    "build": "node --experimental-strip-types build.ts",
    "test": "node --experimental-strip-types --test --test-concurrency=1 --test-isolation=none tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  }
}
